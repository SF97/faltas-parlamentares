---
interface Props {
	title: string;
	description?: string;
}
import { base } from "../lib/base";
const { title, description = "Ausências dos deputados da Assembleia da República na XVII Legislatura." } = Astro.props;
---

<!doctype html>
<html lang="pt-PT">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<title>{title} · Faltas parlamentares</title>
	</head>
	<body>
		<header class="site-header">
			<div class="wrap">
				<a href={base} class="brand">Faltas parlamentares</a>
				<nav>
					<a href={base}>Ranking</a>
					<a href={`${base}/motivos`}>Motivos</a>
					<a href={`${base}/metodologia`}>Metodologia</a>
					<a href={`${base}/transparencia`}>Transparência</a>
				</nav>
			</div>
		</header>
		<main class="wrap">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="wrap">
				<p>Dados do <a href="https://www.parlamento.pt/DeputadoGP/Paginas/reunioesplenarias.aspx">Parlamento</a>. Reunião plenária apenas; não inclui comissões.</p>
			</div>
		</footer>
		<style is:global>
			:root {
				--fg: #1a1a1a;
				--fg-muted: #666;
				--bg: #fafaf8;
				--bg-panel: #fff;
				--border: #e5e3de;
				--accent: #b8272d;
			}
			* { box-sizing: border-box; }
			html, body { margin: 0; padding: 0; }
			body {
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
				color: var(--fg);
				background: var(--bg);
				line-height: 1.5;
				font-size: 16px;
			}
			a { color: var(--accent); text-decoration: none; }
			a:hover { text-decoration: underline; }
			.wrap { max-width: 960px; margin: 0 auto; padding: 0 1rem; }
			.site-header {
				background: var(--bg-panel);
				border-bottom: 1px solid var(--border);
				padding: 1rem 0;
			}
			.site-header .wrap { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
			.brand { font-weight: 700; color: var(--fg); font-size: 1.05rem; }
			.site-header nav { display: flex; gap: 1rem; }
			.site-header nav a { color: var(--fg-muted); }
			.site-header nav a:hover { color: var(--fg); }
			main { padding: 2rem 0 3rem; min-height: 60vh; }
			h1 { font-size: 1.6rem; margin: 0 0 .5rem; }
			h2 { font-size: 1.2rem; margin: 2rem 0 .5rem; }
			p { margin: .5rem 0; }
			.lede { color: var(--fg-muted); margin-bottom: 2rem; }
			.site-footer { border-top: 1px solid var(--border); padding: 1.5rem 0; color: var(--fg-muted); font-size: .875rem; }
			.site-footer a { color: var(--fg-muted); text-decoration: underline; }
			table { width: 100%; border-collapse: separate; border-spacing: 0; background: var(--bg-panel); border: 1px solid var(--border); }
			th, td { text-align: left; padding: .55rem .75rem; border-bottom: 1px solid var(--border); font-size: .95rem; }
			th { background: #f3f1ec; font-weight: 600; color: var(--fg-muted); font-size: .8rem; text-transform: uppercase; letter-spacing: .03em; position: sticky; top: 0; z-index: 1; }
			tr:last-child td { border-bottom: 0; }
			td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
			.gp { display: inline-block; padding: .1rem .45rem; border-radius: 3px; font-size: .75rem; font-weight: 600; color: #fff; letter-spacing: .02em; }
			.gp[data-p="PS"]   { background: #ec407a; }
			.gp[data-p="PSD"]  { background: #f57c00; }
			.gp[data-p="CH"]   { background: #1a3a8a; }
			.gp[data-p="IL"]   { background: #00bcd4; color: #003545; }
			.gp[data-p="BE"]   { background: #b71c1c; }
			.gp[data-p="PCP"]  { background: #c62828; }
			.gp[data-p="L"]    { background: #2e7d32; }
			.gp[data-p="PAN"]  { background: #00695c; }
			.gp[data-p="JPP"]  { background: #6a1b9a; }
			.gp[data-p="CDS-PP"] { background: #0277bd; }
			.badge { display: inline-block; padding: .05rem .4rem; border-radius: 3px; font-size: .72rem; font-weight: 600; }
			.badge.P   { background: #e8f5e9; color: #1b5e20; }
			.badge.FJ  { background: #fff8e1; color: #7a5700; }
			.badge.FI  { background: #ffebee; color: #b71c1c; }
			.badge.AMP { background: #ede7f6; color: #4527a0; }
			.badge.FQV { background: #eceff1; color: #455a64; }
			.badge.PNO { background: #e3f2fd; color: #0d47a1; }
			.legend { display: flex; flex-wrap: wrap; gap: .4rem .9rem; margin: 1rem 0 1.5rem; padding: .6rem .8rem; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 4px; font-size: .85rem; }
			.legend span { display: inline-flex; align-items: center; gap: .35rem; }
			.motivo { color: var(--fg-muted); font-size: .9em; }
			.motivo-list { list-style: none; padding: 0; margin: 1rem 0; display: grid; gap: .25rem; }
			.motivo-list li { display: flex; justify-content: space-between; align-items: baseline; padding: .4rem .6rem; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 4px; }
			.motivo-count { font-variant-numeric: tabular-nums; color: var(--fg-muted); font-size: .85rem; }
			.motivo-more { justify-content: flex-end !important; background: transparent !important; border: 0 !important; padding: .5rem 0 !important; }
			.filters { display: flex; flex-wrap: wrap; gap: .35rem; margin: 1rem 0; }
			.filters button {
				border: 1px solid var(--border); background: var(--bg-panel); color: var(--fg);
				padding: .3rem .7rem; border-radius: 4px; cursor: pointer; font-size: .85rem;
			}
			.filters button[aria-pressed="true"] { background: var(--fg); color: var(--bg-panel); border-color: var(--fg); }
			.card { background: var(--bg-panel); border: 1px solid var(--border); padding: 1rem 1.25rem; border-radius: 6px; margin-bottom: 1rem; }
			.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: .75rem; margin: 1rem 0; }
			.stat { background: var(--bg-panel); border: 1px solid var(--border); padding: .6rem .8rem; border-radius: 4px; }
			.stat .n { font-size: 1.4rem; font-weight: 600; font-variant-numeric: tabular-nums; }
			.stat .l { color: var(--fg-muted); font-size: .75rem; text-transform: uppercase; letter-spacing: .03em; }
		</style>
	</body>
</html>
